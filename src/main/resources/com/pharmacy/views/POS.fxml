<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="640.0" prefWidth="900.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controllers.POSController">

   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="45.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Point of Sale" textFill="#2c3e50">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
               <padding>
                  <Insets left="20.0" />
               </padding>
            </Label>
            <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Invoice: ">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                     <padding>
                        <Insets right="5.0" />
                     </padding>
                  </Label>
                  <Label fx:id="lblInvoice" text="INV-00000000-0000" textFill="#2980b9">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                     <padding>
                        <Insets right="20.0" />
                     </padding>
                  </Label>
               </children>
            </HBox>
         </children>
      </HBox>
   </top>

   <center>
      <VBox spacing="8.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="5.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label text="Available Medicines">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <Pane HBox.hgrow="ALWAYS" />
                  <TextField fx:id="txtMedSearch" prefWidth="200.0" promptText="🔍 Search name, generic, or category..." style="-fx-background-radius: 15;" />
               </children>
            </HBox>
            <TableView fx:id="medicineTable" prefHeight="200.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colMedId" prefWidth="35.0" text="ID" />
                <TableColumn fx:id="colMedName" prefWidth="100.0" text="Name" />
                <TableColumn fx:id="colMedBatch" prefWidth="110.0" text="Batch #" />
                <TableColumn fx:id="colMedPrice" prefWidth="60.0" text="Price" />
                <TableColumn fx:id="colMedTax" prefWidth="50.0" text="Tax %" />
                <TableColumn fx:id="colMedStock" prefWidth="50.0" text="Stock" />
                <TableColumn fx:id="colMedExpiry" prefWidth="85.0" text="Expiry" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>

            <HBox spacing="10.0" alignment="CENTER_LEFT">
               <children>
                  <Label text="Qty:" />
                  <TextField fx:id="txtQuantityToAdd" prefWidth="60.0" promptText="1" />
                  <Button mnemonicParsing="false" onAction="#addToCart" styleClass="primary-button" text="Add to Cart" />
                  <Button mnemonicParsing="false" onAction="#removeFromCart" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;" text="Remove" />
                  <Label fx:id="lblAddError" textFill="RED" />
               </children>
            </HBox>

            <Label text="Shopping Cart">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            <TableView fx:id="cartTable" prefHeight="160.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colCartMedName" prefWidth="120.0" text="Medicine" />
                <TableColumn fx:id="colCartBatch" prefWidth="100.0" text="Batch #" />
                <TableColumn fx:id="colCartPrice" prefWidth="60.0" text="Price" />
                <TableColumn fx:id="colCartQuantity" prefWidth="40.0" text="Qty" />
                <TableColumn fx:id="colCartTax" prefWidth="60.0" text="Tax" />
                <TableColumn fx:id="colCartTotal" prefWidth="70.0" text="Total" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>

            <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-background-color: #d5dbdb; -fx-background-radius: 5;">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
               <children>
                  <Label text="Customer Name:">
                     <font><Font name="System Bold" size="12.0" /></font>
                  </Label>
                  <TextField fx:id="txtCustomerName" prefWidth="150.0" promptText="Enter Name" />
                  <Label text="Contact #:">
                     <font><Font name="System Bold" size="12.0" /></font>
                  </Label>
                  <TextField fx:id="txtCustomerContact" prefWidth="120.0" promptText="Phone Number" />
               </children>
            </HBox>

            <HBox spacing="20.0" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 5;">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
               <children>
                  <VBox spacing="3.0">
                     <Label text="Subtotal:">
                        <font><Font name="System Bold" size="12.0" /></font>
                     </Label>
                     <Label fx:id="lblSubtotal" text="0.00" />
                  </VBox>
                  <VBox spacing="3.0">
                     <Label text="Tax:">
                        <font><Font name="System Bold" size="12.0" /></font>
                     </Label>
                     <Label fx:id="lblTax" text="0.00" />
                  </VBox>
                  <VBox spacing="3.0">
                     <Label text="Grand Total:">
                        <font><Font name="System Bold" size="12.0" /></font>
                     </Label>
                     <Label fx:id="lblTotal" text="0.00" textFill="#27ae60">
                        <font><Font name="System Bold" size="18.0" /></font>
                     </Label>
                  </VBox>
                  <VBox spacing="3.0">
                     <Label text="Payment:">
                        <font><Font name="System Bold" size="12.0" /></font>
                     </Label>
                     <ComboBox fx:id="cmbPaymentMethod" prefWidth="100.0" />
                  </VBox>
                  <VBox alignment="CENTER">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleCheckout" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;" text="Complete Sale">
                           <font><Font name="System Bold" size="14.0" /></font>
                           <padding><Insets bottom="10.0" left="25.0" right="25.0" top="10.0" /></padding>
                        </Button>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>
