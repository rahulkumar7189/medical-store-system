<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="640.0" prefWidth="900.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controllers.InventoryController">
   
   <top>
      <VBox spacing="5.0" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="45.0">
               <children>
                  <Label text="Inventory Management" textFill="#2c3e50">
                     <font>
                        <Font name="System Bold" size="22.0" />
                     </font>
                     <padding>
                        <Insets left="20.0" />
                     </padding>
                  </Label>
               </children>
            </HBox>
            <Label fx:id="lblAlertBanner" style="-fx-background-color: #fff3cd; -fx-padding: 8 15; -fx-font-size: 13; -fx-border-color: #ffc107; -fx-border-width: 0 0 1 0;" text="" wrapText="true">
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
            </Label>
         </children>
      </VBox>
   </top>

   <center>
      <VBox BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <TableView fx:id="medicineTable" prefHeight="550.0" prefWidth="600.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />
                <TableColumn fx:id="colName" prefWidth="100.0" text="Name" />
                <TableColumn fx:id="colBatch" prefWidth="110.0" text="Batch #" />
                <TableColumn fx:id="colGeneric" prefWidth="90.0" text="Generic" />
                <TableColumn fx:id="colCategory" prefWidth="80.0" text="Category" />
                <TableColumn fx:id="colPrice" prefWidth="60.0" text="Price" />
                <TableColumn fx:id="colTaxRate" prefWidth="50.0" text="Tax %" />
                <TableColumn fx:id="colQuantity" prefWidth="50.0" text="Stock" />
                <TableColumn fx:id="colReorder" prefWidth="60.0" text="Reorder" />
                <TableColumn fx:id="colExpiry" prefWidth="85.0" text="Expiry" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </center>

   <right>
      <VBox prefWidth="270.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 5;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
         </padding>
         <BorderPane.margin>
            <Insets bottom="10.0" right="10.0" top="10.0" />
         </BorderPane.margin>
         <children>
            <Label text="Add New Medicine">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="5.0" />
               </VBox.margin>
            </Label>
            
            <VBox spacing="2.0">
               <Label text="Name *" />
               <TextField fx:id="txtName" promptText="e.g. Tylenol" />
            </VBox>

            <VBox spacing="2.0">
               <Label text="Generic Name" />
               <TextField fx:id="txtGeneric" promptText="e.g. Paracetamol" />
            </VBox>

            <VBox spacing="2.0">
               <Label text="Batch Number" />
               <TextField fx:id="txtBatch" promptText="e.g. BATCH-PFZ-2026A" />
            </VBox>

            <VBox spacing="2.0">
               <Label text="Category" />
               <TextField fx:id="txtCategory" promptText="e.g. Painkiller" />
            </VBox>
            
            <HBox spacing="8.0">
               <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                  <Label text="Price *" />
                  <TextField fx:id="txtPrice" promptText="0.00" />
               </VBox>
               <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                  <Label text="Tax %" />
                  <TextField fx:id="txtTaxRate" promptText="5.00" />
               </VBox>
            </HBox>

            <HBox spacing="8.0">
               <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                  <Label text="Qty *" />
                  <TextField fx:id="txtQuantity" promptText="0" />
               </VBox>
               <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                  <Label text="Reorder Lvl" />
                  <TextField fx:id="txtReorder" promptText="10" />
               </VBox>
            </HBox>
            
            <VBox spacing="2.0">
               <Label text="Expiry Date *" />
               <DatePicker fx:id="dateExpiry" maxWidth="1.7976931348623157E308" />
            </VBox>

            <Label fx:id="lblStatus" textFill="RED" wrapText="true">
               <font>
                  <Font size="11.0" />
               </font>
            </Label>
            
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAddMedicine" styleClass="primary-button" text="Save Medicine">
               <font>
                  <Font size="13.0" />
               </font>
            </Button>
            
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clearForm" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;" text="Clear Form">
               <font>
                  <Font size="13.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </right>
</BorderPane>
