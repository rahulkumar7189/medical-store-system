<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controllers.SearchController">
   <content>
      <VBox spacing="20.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="15.0" />
         </padding>
         <children>
            <Label fx:id="lblSearchTitle" text="Global Search Results" textFill="#2c3e50">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
            </Label>

            <!-- Medicines Section -->
            <VBox spacing="5.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
               <children>
                  <Label text="Medicines Found" textFill="#2980b9">
                     <font><Font name="System Bold" size="16.0" /></font>
                  </Label>
                  <TableView fx:id="medicineTable" prefHeight="150.0">
                    <columns>
                      <TableColumn fx:id="colMedName" prefWidth="150.0" text="Name" />
                      <TableColumn fx:id="colMedBatch" prefWidth="120.0" text="Batch #" />
                      <TableColumn fx:id="colMedStock" prefWidth="80.0" text="Stock" />
                      <TableColumn fx:id="colMedExpiry" prefWidth="100.0" text="Expiry" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>

            <!-- Suppliers Section -->
            <VBox spacing="5.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
               <children>
                  <Label text="Suppliers Found" textFill="#27ae60">
                     <font><Font name="System Bold" size="16.0" /></font>
                  </Label>
                  <TableView fx:id="supplierTable" prefHeight="150.0">
                    <columns>
                      <TableColumn fx:id="colSupName" prefWidth="200.0" text="Company Name" />
                      <TableColumn fx:id="colSupContact" prefWidth="250.0" text="Contact Info" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>

            <!-- Audit Logs Section -->
            <VBox spacing="5.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
               <children>
                  <Label text="System Activities Found" textFill="#e67e22">
                     <font><Font name="System Bold" size="16.0" /></font>
                  </Label>
                  <TableView fx:id="logTable" prefHeight="150.0">
                    <columns>
                      <TableColumn fx:id="colLogUser" prefWidth="100.0" text="User" />
                      <TableColumn fx:id="colLogAction" prefWidth="150.0" text="Action" />
                      <TableColumn fx:id="colLogTime" prefWidth="150.0" text="Timestamp" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
         </children>
      </VBox>
   </content>
</ScrollPane>
