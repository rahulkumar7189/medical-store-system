<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="640.0" prefWidth="900.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controllers.AuditTrailController">

   <top>
      <HBox alignment="CENTER_LEFT" spacing="15.0" prefHeight="50.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets left="20.0" right="20.0" />
         </padding>
         <children>
            <Label text="Audit Trail" textFill="#2c3e50">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
            </Label>
            <HBox alignment="CENTER_RIGHT" spacing="8.0" HBox.hgrow="ALWAYS">
               <children>
                  <TextField fx:id="txtSearch" prefWidth="200.0" promptText="Search user, action..." />
                  <Button mnemonicParsing="false" onAction="#handleSearch" styleClass="primary-button" text="Search" />
                  <Button mnemonicParsing="false" onAction="#handleRefresh" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;" text="Refresh" />
               </children>
            </HBox>
         </children>
      </HBox>
   </top>

   <center>
      <VBox BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="5.0" />
         </padding>
         <children>
            <TableView fx:id="auditTable" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="colUser" prefWidth="100.0" text="User" />
                <TableColumn fx:id="colAction" prefWidth="150.0" text="Action" />
                <TableColumn fx:id="colDetails" prefWidth="300.0" text="Details" />
                <TableColumn fx:id="colTimestamp" prefWidth="150.0" text="Timestamp" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </center>
</BorderPane>
