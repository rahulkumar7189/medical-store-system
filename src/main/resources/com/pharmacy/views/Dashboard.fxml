<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controllers.DashboardController">
   
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
         <children>
            <Label text="Medical Store System" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
               <padding>
                  <Insets left="20.0" />
               </padding>
            </Label>
            <HBox alignment="CENTER" spacing="5.0" HBox.hgrow="ALWAYS">
               <children>
                  <TextField fx:id="txtGlobalSearch" prefWidth="250.0" promptText="Search medicines, suppliers, batches..." style="-fx-background-radius: 15;" />
                  <Button mnemonicParsing="false" onAction="#handleGlobalSearch" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 15; -fx-cursor: hand;" text="Search" />
               </children>
            </HBox>
            <HBox alignment="CENTER_RIGHT">
               <children>
                  <Label fx:id="welcomeLabel" text="Welcome, User!" textFill="WHITE">
                     <font>
                        <Font size="14.0" />
                     </font>
                     <padding>
                        <Insets right="20.0" />
                     </padding>
                  </Label>
               </children>
            </HBox>
         </children>
      </HBox>
   </top>


   
   <left>
      <VBox prefWidth="200.0" spacing="8.0" style="-fx-background-color: #34495e;" BorderPane.alignment="CENTER">
         <children>
            <Label text="MODULES" textFill="#95a5a6" style="-fx-font-size: 11; -fx-font-weight: bold;">
               <padding>
                  <Insets left="15.0" top="5.0" />
               </padding>
            </Label>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#loadInventory" styleClass="sidebar-btn" text="📦 Inventory" textFill="WHITE">
               <font><Font size="14.0" /></font>
               <padding><Insets bottom="12.0" left="15.0" top="12.0" /></padding>
            </Button>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#loadPOS" styleClass="sidebar-btn" text="🛒 Point of Sale" textFill="WHITE">
               <font><Font size="14.0" /></font>
               <padding><Insets bottom="12.0" left="15.0" top="12.0" /></padding>
            </Button>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#loadSuppliers" styleClass="sidebar-btn" text="🏢 Suppliers" textFill="WHITE">
               <font><Font size="14.0" /></font>
               <padding><Insets bottom="12.0" left="15.0" top="12.0" /></padding>
            </Button>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#loadCustomers" styleClass="sidebar-btn" text="👥 Customers" textFill="WHITE">
               <font><Font size="14.0" /></font>
               <padding><Insets bottom="12.0" left="15.0" top="12.0" /></padding>
            </Button>

            <Label text="ANALYTICS" textFill="#95a5a6" style="-fx-font-size: 11; -fx-font-weight: bold;">
               <padding>
                  <Insets left="15.0" top="10.0" />
               </padding>
            </Label>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#loadReports" styleClass="sidebar-btn" text="📊 Reports" textFill="WHITE">
               <font><Font size="14.0" /></font>
               <padding><Insets bottom="12.0" left="15.0" top="12.0" /></padding>
            </Button>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#loadAuditTrail" styleClass="sidebar-btn" text="📝 Audit Trail" textFill="WHITE">
               <font><Font size="14.0" /></font>
               <padding><Insets bottom="12.0" left="15.0" top="12.0" /></padding>
            </Button>

            <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS">
               <children>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#logout" style="-fx-background-color: #e74c3c; -fx-cursor: hand;" text="Logout" textFill="WHITE">
                     <font><Font size="14.0" /></font>
                     <padding><Insets bottom="12.0" left="15.0" top="12.0" /></padding>
                  </Button>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="15.0" top="15.0" />
         </padding>
      </VBox>
   </left>

   <center>
      <StackPane fx:id="contentArea" style="-fx-background-color: #f4f6f8;" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label text="Select a Module from the Sidebar" textFill="#7f8c8d">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
         </children>
      </StackPane>
   </center>
   
</BorderPane>
