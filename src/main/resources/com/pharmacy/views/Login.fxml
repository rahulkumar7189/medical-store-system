<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" styleClass="main-container" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controllers.LoginController">
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>
   <children>
      <Label text="Medical Store System" textFill="#2c3e50">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </Label>
      
      <VBox maxWidth="300.0" spacing="5.0">
         <children>
            <Label text="Username" />
            <TextField fx:id="usernameField" promptText="Enter username" style="-fx-padding: 10;" />
         </children>
      </VBox>
      
      <VBox maxWidth="300.0" spacing="5.0">
         <children>
            <Label text="Password" />
            <PasswordField fx:id="passwordField" promptText="Enter password" style="-fx-padding: 10;" />
         </children>
      </VBox>
      
      <Label fx:id="errorLabel" textFill="#e74c3c" wrapText="true">
         <font>
            <Font size="13.0" />
         </font>
      </Label>
      
      <Button fx:id="loginButton" maxWidth="300.0" mnemonicParsing="false" onAction="#handleLogin" styleClass="primary-button" text="Login">
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Button>
   </children>
</VBox>
